# =============================================================================
# playgauge_framework — environment variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and NEVER committed.
# =============================================================================

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Select your AI backend for test failure analysis.
#
# AI_PROVIDER options:
#   anthropic          → Anthropic Claude (default, SDK already installed)
#   openai             → OpenAI GPT-4o etc  (run: npm install openai)
#   gemini             → Google Gemini      (run: npm install @google/generative-ai)
#   openai-compatible  → Any OpenAI-compatible REST API (Groq, Together, Ollama, Azure, Mistral)
#                        (run: npm install openai  +  set AI_BASE_URL below)
#
AI_PROVIDER=anthropic

# Your API key for the selected provider.
# Anthropic  → https://console.anthropic.com/settings/keys
# OpenAI     → https://platform.openai.com/api-keys
# Gemini     → https://aistudio.google.com/app/apikey
# Groq       → https://console.groq.com/keys
# Together   → https://api.together.xyz/settings/api-keys
AI_API_KEY=

# Model to use. Leave blank to use the recommended default for your provider.
# Anthropic defaults:  claude-3-5-sonnet-20241022
# OpenAI defaults:     gpt-4o
# Gemini defaults:     gemini-1.5-pro
# Groq defaults:       llama-3.1-70b-versatile (set explicitly — no default)
#AI_MODEL=

# Base URL — required ONLY for AI_PROVIDER=openai-compatible
# Examples:
#   Groq:       AI_BASE_URL=https://api.groq.com/openai/v1
#   Together:   AI_BASE_URL=https://api.together.xyz/v1
#   Mistral:    AI_BASE_URL=https://api.mistral.ai/v1
#   Ollama:     AI_BASE_URL=http://localhost:11434/v1   (AI_API_KEY=ollama)
#   Azure:      AI_BASE_URL=https://<resource>.openai.azure.com
#AI_BASE_URL=

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Only needed when DB_ENABLED=true (CI/CD testrunner environments).
# Local runs do NOT require PostgreSQL.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=playgauge
POSTGRES_USER=playgauge_user
POSTGRES_PASSWORD=your_db_password_here

# ─── Active environment ───────────────────────────────────────────────────────
GAUGE_ENV=dev

# ─── Optional overrides ───────────────────────────────────────────────────────
# Values here take precedence over env/<GAUGE_ENV>/default.properties.
# Useful for local developer overrides only — do not commit these.
# BASE_URL=https://localhost:3000
# HEADLESS=false
# SLOW_API_THRESHOLD_MS=2000
